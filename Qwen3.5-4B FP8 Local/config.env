# ============================================================
#  SERVER CONFIGURATION — Edit these to tune the model
#  Restart start.bat after any changes
# ============================================================

# --- Model ---
MODEL=lovedheart/Qwen3.5-4B-FP8
PORT=8001
HF_CACHE=/mnt/c/Users/mojtaba/.cache/huggingface

# --- VRAM ---
# How much of total GPU VRAM to reserve (0.0 to 1.0)
# Too high → startup fails | Too low → less KV cache (shorter context)
# Formula: value × total_VRAM must be < free_VRAM_at_startup
GPU_MEMORY_UTILIZATION=0.88

# --- Context Window ---
# Max total tokens (input + output). Higher = more VRAM for KV cache.
# 4096=short  8192=medium  16384=long files  32768=very large (needs VRAM)
MAX_MODEL_LEN=65536

# --- KV Cache Precision ---
# fp8 = half the KV cache memory (recommended)
# auto = use model default (bf16 = 2x memory)
KV_CACHE_DTYPE=fp8

# --- Startup Mode ---
# true  = skip CUDA graph compilation (fast start ~2min, ~same speed for chat)
# false = full compile (30-60min first time, cached after, ~10% faster tokens)
ENFORCE_EAGER=true

# ============================================================
#  PER-REQUEST DEFAULTS  (also set in Continue config.yaml)
#  These control quality vs creativity vs speed of responses
# ============================================================

# Max tokens the model can output per response
# Lower = faster | Higher = longer answers
# Must satisfy: MAX_TOKENS + prompt_tokens <= MAX_MODEL_LEN
MAX_TOKENS=4096

# Creativity / Randomness  (0.0 = deterministic, 1.0 = creative, 2.0 = chaotic)
# 0.0-0.3 = precise code/facts | 0.6-0.7 = balanced | 1.0+ = creative writing
TEMPERATURE=0.6

# Nucleus sampling — limits token pool to top P% probability mass (0.0-1.0)
# 0.9 is standard. Lower = more conservative. 1.0 = no filtering.
TOP_P=0.9

# Hard cap on candidate tokens per step. 1=greedy. 50=standard. 0=disabled.
TOP_K=50
