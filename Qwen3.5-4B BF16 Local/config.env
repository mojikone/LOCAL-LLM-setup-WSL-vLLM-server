# ============================================================
#  SERVER CONFIGURATION — Edit these to tune the model
#  Restart start.bat after any changes
# ============================================================

# --- Model ---
MODEL=Qwen/Qwen3.5-4B
PORT=8002
HF_CACHE=/mnt/c/Users/mojtaba/.cache/huggingface

# --- VRAM ---
GPU_MEMORY_UTILIZATION=0.88

# --- Context Window ---
MAX_MODEL_LEN=16384

# --- KV Cache Precision ---
KV_CACHE_DTYPE=fp8

# --- Startup Mode ---
ENFORCE_EAGER=true

# ============================================================
#  PER-REQUEST DEFAULTS
# ============================================================

MAX_TOKENS=4096
TEMPERATURE=0.6
TOP_P=0.9
TOP_K=50
