# ============================================================
#  SERVER CONFIGURATION — Edit these to tune the model
#  Restart start.bat after any changes
# ============================================================

# --- Model ---
MODEL=lovedheart/Qwen3.5-9B-FP8
PORT=8000
HF_CACHE=/mnt/c/Users/mojtaba/.cache/huggingface

# --- VRAM ---
# Must satisfy: value × 15.92 GB < 14.52 GB (free VRAM at startup)
# 0.91 is the max safe value for RTX 5080 with this model
GPU_MEMORY_UTILIZATION=0.91

# --- Context Window ---
# 8192 is max for 9B fp8 on 16 GB VRAM (KV cache constraint)
MAX_MODEL_LEN=8192

# --- KV Cache Precision ---
KV_CACHE_DTYPE=fp8

# --- Startup Mode ---
# true = fast start ~2min | false = full compile 30-60min (faster tokens after)
ENFORCE_EAGER=true

# ============================================================
#  PER-REQUEST DEFAULTS  (also configured in Continue config.yaml)
# ============================================================

# Max output tokens. Must satisfy: MAX_TOKENS + prompt_tokens <= MAX_MODEL_LEN
MAX_TOKENS=2048

# Creativity / Randomness  (0.0=deterministic, 0.6=balanced, 1.0=creative)
TEMPERATURE=0.6

# Nucleus sampling (0.9 = standard)
TOP_P=0.9

# Hard cap on candidate tokens (50 = standard, 1 = greedy/deterministic)
TOP_K=50
